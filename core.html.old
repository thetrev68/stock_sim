<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paper Trader</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.7.1/dist/chart.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-date-fns/dist/chartjs-adapter-date-fns.bundle.min.js"></script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .ticker-symbol { font-variant-caps: all-small-caps; }
        .nav-link-active { color: #22d3ee; border-bottom-color: #22d3ee; }
        .range-btn-active { background-color: #0891b2; color: white; }
    </style>
</head>
<body class="bg-gray-900 text-white antialiased">
    <div id="app" class="max-w-5xl mx-auto p-4 sm:p-6 lg:p-8">
        <!-- Header -->
        <header class="flex flex-col sm:flex-row justify-between sm:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-bold text-cyan-400">Paper Trader</h1>
                <p class="text-gray-400">Invest with zero risk.</p>
            </div>
            <div id="status-indicator" class="flex items-center space-x-2">
                <div class="w-3 h-3 rounded-full bg-gray-500 animate-pulse"></div>
                <span class="text-gray-400 text-sm">Connecting...</span>
            </div>
        </header>

        <!-- API Key Input -->
        <div id="api-key-section" class="bg-gray-800 p-6 rounded-lg mb-8 shadow-lg border border-gray-700">
            <h2 class="text-xl font-semibold mb-3">Setup Required</h2>
            <p class="text-gray-400 mb-4">To get live stock prices, you need a free API key from Finnhub.io.</p>
            <div class="flex flex-col sm:flex-row gap-4">
                <input type="text" id="api-key-input" placeholder="Paste your Finnhub API key here" class="flex-grow bg-gray-700 text-white placeholder-gray-500 rounded-md px-4 py-2 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500 transition">
                <button id="save-api-key-btn" class="bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-6 rounded-md transition-colors duration-300">Save & Connect</button>
            </div>
            <p class="text-xs text-gray-500 mt-3"><a href="https://finnhub.io/register" target="_blank" class="underline hover:text-cyan-400">Click here to get your free key.</a> Your key is saved only in your browser.</p>
        </div>

        <!-- Main Content Area -->
        <div id="app-content" class="hidden">
            <!-- Navigation -->
            <nav class="flex border-b border-gray-700 mb-8">
                <button id="nav-portfolio" class="nav-link py-4 px-6 text-gray-300 hover:text-cyan-400 border-b-2 border-transparent transition">Portfolio</button>
                <button id="nav-research" class="nav-link py-4 px-6 text-gray-300 hover:text-cyan-400 border-b-2 border-transparent transition">Research</button>
                <button id="nav-watchlist" class="nav-link py-4 px-6 text-gray-300 hover:text-cyan-400 border-b-2 border-transparent transition">Watchlist</button>
            </nav>

            <!-- Portfolio Page -->
            <main id="page-portfolio" class="page-content">
                <section id="portfolio-summary" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                    <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                        <h3 class="text-sm font-medium text-gray-400">Portfolio Value</h3>
                        <p id="total-value" class="text-2xl font-semibold text-white">$0.00</p>
                    </div>
                    <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                        <h3 class="text-sm font-medium text-gray-400">Stock Holdings</h3>
                        <p id="stocks-value" class="text-2xl font-semibold text-white">$0.00</p>
                    </div>
                    <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                        <h3 class="text-sm font-medium text-gray-400">Available Cash</h3>
                        <p id="cash-value" class="text-2xl font-semibold text-green-400">$0.00</p>
                    </div>
                    <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                        <h3 class="text-sm font-medium text-gray-400">Today's P/L</h3>
                        <p id="today-pl" class="text-2xl font-semibold text-gray-500">$0.00</p>
                    </div>
                </section>
                
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="lg:col-span-1">
                        <div class="bg-gray-800 p-6 rounded-lg shadow-lg sticky top-8">
                            <h2 class="text-xl font-semibold mb-4">Make a Trade</h2>
                            <div class="space-y-4">
                                <div>
                                    <label for="ticker" class="block text-sm font-medium text-gray-300 mb-1">Ticker Symbol</label>
                                    <input type="text" id="ticker" class="w-full bg-gray-700 text-white rounded-md px-3 py-2 border border-gray-600 uppercase focus:outline-none focus:ring-2 focus:ring-cyan-500" placeholder="e.g., AAPL, TSLA">
                                </div>
                                <div>
                                    <label for="quantity" class="block text-sm font-medium text-gray-300 mb-1">Quantity</label>
                                    <input type="number" id="quantity" min="1" class="w-full bg-gray-700 text-white rounded-md px-3 py-2 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500" placeholder="e.g., 10">
                                </div>
                                <div class="flex gap-4">
                                    <button id="buy-btn" class="w-full bg-green-600 hover:bg-green-500 text-white font-bold py-2 rounded-md transition-colors duration-300">Buy</button>
                                    <button id="sell-btn" class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-2 rounded-md transition-colors duration-300">Sell</button>
                                </div>
                            </div>
                            <div id="trade-feedback" class="mt-4 text-sm text-center">&nbsp;</div>
                        </div>
                    </div>
                    
                    <div class="lg:col-span-2">
                        <h2 class="text-xl font-semibold mb-4 text-gray-300">My Holdings</h2>
                        <div id="holdings-list" class="space-y-4">
                            <div class="bg-gray-800 p-4 rounded-lg flex items-center justify-between shadow-md hidden" id="holdings-placeholder">
                                <p class="text-center text-gray-400 w-full">You don't own any stocks yet. Buy one to get started!</p>
                            </div>
                        </div>
                    </div>
                </div>
            </main>

            <!-- Research Page -->
            <main id="page-research" class="page-content hidden">
                <div class="bg-gray-800 p-6 rounded-lg shadow-lg mb-8">
                    <h2 class="text-xl font-semibold mb-4">Research a Stock</h2>
                    <div class="flex flex-col sm:flex-row gap-4 mb-4">
                        <input type="text" id="research-ticker-input" placeholder="Enter ticker (e.g., TSLA)" class="flex-grow bg-gray-700 text-white placeholder-gray-500 rounded-md px-4 py-2 border border-gray-600 uppercase focus:outline-none focus:ring-2 focus:ring-cyan-500 transition">
                        <button id="research-btn" class="bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-6 rounded-md transition-colors duration-300">Get Info</button>
                    </div>
                </div>

                <div id="research-results" class="hidden">
                    <div class="bg-gray-800 p-6 rounded-lg shadow-lg mb-8">
                        <div id="price-info" class="mb-4"></div>
                        <div class="mb-4 h-80">
                            <canvas id="stock-chart"></canvas>
                        </div>
                        <div id="range-selector" class="flex justify-center gap-2 flex-wrap">
                            <button data-range="1D" class="range-btn px-3 py-1 text-sm rounded-md bg-gray-700 hover:bg-gray-600 transition">1D</button>
                            <button data-range="5D" class="range-btn px-3 py-1 text-sm rounded-md bg-gray-700 hover:bg-gray-600 transition">5D</button>
                            <button data-range="1M" class="range-btn px-3 py-1 text-sm rounded-md bg-gray-700 hover:bg-gray-600 transition">1M</button>
                            <button data-range="6M" class="range-btn px-3 py-1 text-sm rounded-md bg-gray-700 hover:bg-gray-600 transition">6M</button>
                            <button data-range="1Y" class="range-btn px-3 py-1 text-sm rounded-md bg-gray-700 hover:bg-gray-600 transition">1Y</button>
                        </div>
                    </div>
                    
                    <div id="company-profile" class="mb-8"></div>

                    <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-xl font-semibold text-gray-300">Latest News</h3>
                            <div class="flex items-center">
                                <input type="checkbox" id="free-news-toggle" class="h-4 w-4 rounded border-gray-500 text-cyan-600 focus:ring-cyan-500 bg-gray-700 cursor-pointer">
                                <label for="free-news-toggle" class="ml-2 block text-sm text-gray-300 cursor-pointer">Free articles only</label>
                            </div>
                        </div>
                        <div id="company-news" class="space-y-4"></div>
                    </div>
                </div>
                
                <div id="research-placeholder" class="text-center text-gray-400 py-12">
                    <p>Enter a stock ticker above to see company details and news.</p>
                </div>
                
                <div id="research-loading" class="text-center text-gray-400 py-12 hidden">
                    <div class="w-8 h-8 border-4 border-cyan-400 border-t-transparent rounded-full animate-spin mx-auto mb-4"></div>
                    <p>Fetching data...</p>
                </div>
            </main>

            <!-- Watchlist Page -->
            <main id="page-watchlist" class="page-content hidden">
                <div class="bg-gray-800 p-6 rounded-lg shadow-lg mb-8">
                    <h2 class="text-xl font-semibold mb-4">Stock Watchlist</h2>
                    <div class="flex flex-col sm:flex-row gap-4 mb-4">
                        <input type="text" id="watchlist-ticker-input" placeholder="Add ticker to watchlist" class="flex-grow bg-gray-700 text-white placeholder-gray-500 rounded-md px-4 py-2 border border-gray-600 uppercase focus:outline-none focus:ring-2 focus:ring-cyan-500 transition">
                        <button id="add-watchlist-btn" class="bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-6 rounded-md transition-colors duration-300">Add to Watchlist</button>
                    </div>
                </div>
                
                <div id="watchlist-container" class="space-y-4">
                    <div id="watchlist-placeholder" class="bg-gray-800 p-8 rounded-lg text-center text-gray-400">
                        <p>Your watchlist is empty. Add some stocks to track their prices!</p>
                    </div>
                </div>
            </main>
        </div>
        
        <!-- Message Modal -->
        <div id="message-modal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center hidden z-50">
            <div class="bg-gray-800 rounded-lg p-8 max-w-sm w-full shadow-2xl border border-gray-700">
                <h3 id="modal-title" class="text-xl font-bold text-white mb-4">Alert</h3>
                <p id="modal-message" class="text-gray-300 mb-6">This is a sample message.</p>
                <button id="modal-close-btn" class="w-full bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-4 rounded-md transition-colors duration-300">Close</button>
            </div>
        </div>
    </div>

<script>
// Global state
let apiKey = '';
let portfolio = { cash: 10000, stocks: {} };
let watchlist = [];
let livePrices = {};
let updateInterval;
let activeView = 'portfolio';
let filterFreeNews = true;
let lastResearched = { ticker: null, profile: null, news: null, quote: null };
let chartInstance = null;
let lastApiCall = 0;
const API_DELAY = 1100;

const freeNewsSources = ['Yahoo Finance', 'Reuters', 'CNBC', 'MarketWatch', 'Business Insider', 'Seeking Alpha', 'The Motley Fool', 'Zacks Investment Research', 'Associated Press', 'PR Newswire', 'GlobeNewswire', 'Benzinga', 'Accesswire'];

// Utility functions
const formatCurrency = (amount) => new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
const formatMarketCap = (num) => (num / 1000).toFixed(2) + 'B';

const showModal = (title, message) => {
    document.getElementById('modal-title').textContent = title;
    document.getElementById('modal-message').textContent = message;
    document.getElementById('message-modal').classList.remove('hidden');
};

const hideModal = () => document.getElementById('message-modal').classList.add('hidden');

const waitForApiDelay = async () => {
    const now = Date.now();
    const timeSinceLastCall = now - lastApiCall;
    if (timeSinceLastCall < API_DELAY) {
        await new Promise(resolve => setTimeout(resolve, API_DELAY - timeSinceLastCall));
    }
    lastApiCall = Date.now();
};

const updateStatus = (text, colorClass) => {
    const dot = document.getElementById('status-indicator').querySelector('div');
    const span = document.getElementById('status-indicator').querySelector('span');
    dot.className = `w-3 h-3 rounded-full ${colorClass}`;
    span.textContent = text;
};

// API functions
const fetchFromFinnhub = async (endpoint) => {
    if (!apiKey) {
        updateStatus('Error: API Key Missing', 'bg-red-500');
        return null;
    }
    
    await waitForApiDelay();
    
    try {
        const response = await fetch(`https://finnhub.io/api/v1/${endpoint}&token=${apiKey}`);
        if (response.status === 429) {
            showModal('API Limit Reached', 'Too many requests. Please wait before trying again.');
            updateStatus('API Rate Limit', 'bg-red-500');
            return null;
        }
        if (!response.ok) throw new Error(`API request failed: ${response.status}`);
        const data = await response.json();
        if (data.s === 'no_data' || Object.keys(data).length === 0) return null;
        return data;
    } catch (error) {
        console.error(`Error fetching ${endpoint}:`, error);
        updateStatus('API Error', 'bg-red-500');
        return null;
    }
};

const getStockQuote = (ticker) => fetchFromFinnhub(`quote?symbol=${ticker.toUpperCase()}`);
const getCompanyProfile = (ticker) => fetchFromFinnhub(`stock/profile2?symbol=${ticker.toUpperCase()}`);
const getCompanyNews = (ticker) => {
    const to = new Date().toISOString().split('T')[0];
    const from = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString().split('T')[0];
    return fetchFromFinnhub(`company-news?symbol=${ticker.toUpperCase()}&from=${from}&to=${to}`);
};
const getStockCandles = (ticker, resolution, from, to) => 
    fetchFromFinnhub(`stock/candle?symbol=${ticker.toUpperCase()}&resolution=${resolution}&from=${from}&to=${to}`);

// State management
const saveState = () => {
    localStorage.setItem('paperTraderPortfolio', JSON.stringify(portfolio));
    localStorage.setItem('paperTraderWatchlist', JSON.stringify(watchlist));
    localStorage.setItem('paperTraderApiKey', apiKey);
    localStorage.setItem('paperTraderFreeNewsFilter', JSON.stringify(filterFreeNews));
};

const loadState = () => {
    const savedPortfolio = localStorage.getItem('paperTraderPortfolio');
    const savedWatchlist = localStorage.getItem('paperTraderWatchlist');
    const savedApiKey = localStorage.getItem('paperTraderApiKey');
    const savedFilter = localStorage.getItem('paperTraderFreeNewsFilter');
    
    if (savedPortfolio) portfolio = JSON.parse(savedPortfolio);
    if (savedWatchlist) watchlist = JSON.parse(savedWatchlist);
    if (savedFilter !== null) filterFreeNews = JSON.parse(savedFilter);
    document.getElementById('free-news-toggle').checked = filterFreeNews;
    
    if (savedApiKey) {
        apiKey = savedApiKey;
        document.getElementById('api-key-input').value = apiKey;
        document.getElementById('api-key-section').classList.add('hidden');
        document.getElementById('app-content').classList.remove('hidden');
        initializeApp();
    }
};

const switchView = (view) => {
    activeView = view;
    document.querySelectorAll('.page-content').forEach(p => p.classList.add('hidden'));
    document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('nav-link-active'));
    document.getElementById(`page-${view}`).classList.remove('hidden');
    document.getElementById(`nav-${view}`).classList.add('nav-link-active');
};

// Watchlist functions
const renderWatchlist = () => {
    const container = document.getElementById('watchlist-container');
    const placeholder = document.getElementById('watchlist-placeholder');
    container.innerHTML = '';
    
    if (watchlist.length === 0) {
        container.appendChild(placeholder);
        return;
    }

    watchlist.forEach(ticker => {
        const price = livePrices[ticker];
        if (!price) return;

        const change = price.d || 0;
        const changePercent = price.dp || 0;
        const colorClass = change >= 0 ? 'text-green-400' : 'text-red-400';

        const watchlistItem = document.createElement('div');
        watchlistItem.className = 'bg-gray-800 p-4 rounded-lg flex justify-between items-center shadow-md hover:bg-gray-700 transition';
        watchlistItem.innerHTML = `
            <div>
                <p class="font-bold text-lg text-white ticker-symbol">${ticker}</p>
                <p class="text-sm text-gray-400">Current Price</p>
            </div>
            <div class="text-right">
                <p class="font-semibold text-lg text-white">${formatCurrency(price.c)}</p>
                <p class="text-sm ${colorClass}">${formatCurrency(change)} (${changePercent.toFixed(2)}%)</p>
            </div>
            <button onclick="removeFromWatchlist('${ticker}')" class="ml-4 text-red-400 hover:text-red-300 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        `;
        container.appendChild(watchlistItem);
    });
};

const addToWatchlist = async () => {
    const ticker = document.getElementById('watchlist-ticker-input').value.trim().toUpperCase();
    if (!ticker) {
        showModal('Invalid Input', 'Please enter a ticker symbol.');
        return;
    }
    if (watchlist.includes(ticker)) {
        showModal('Already Added', `${ticker} is already in your watchlist.`);
        return;
    }

    const quote = await getStockQuote(ticker);
    if (!quote) {
        showModal('Invalid Ticker', `Could not find stock "${ticker}".`);
        return;
    }

    watchlist.push(ticker);
    livePrices[ticker] = quote;
    saveState();
    renderWatchlist();
    document.getElementById('watchlist-ticker-input').value = '';
};

const removeFromWatchlist = (ticker) => {
    watchlist = watchlist.filter(t => t !== ticker);
    saveState();
    renderWatchlist();
};

// Portfolio functions
const updatePortfolioSummary = () => {
    let totalStockValue = 0, totalDayStartValue = 0;
    Object.keys(portfolio.stocks).forEach(ticker => {
        const stock = portfolio.stocks[ticker];
        const currentPrice = livePrices[ticker]?.c || stock.purchasePrice;
        const previousPrice = livePrices[ticker]?.pc || stock.purchasePrice;
        totalStockValue += stock.quantity * currentPrice;
        totalDayStartValue += stock.quantity * previousPrice;
    });
    
    const totalPortfolioValue = portfolio.cash + totalStockValue;
    const dailyPl = totalStockValue - totalDayStartValue;
    
    document.getElementById('total-value').textContent = formatCurrency(totalPortfolioValue);
    document.getElementById('stocks-value').textContent = formatCurrency(totalStockValue);
    document.getElementById('cash-value').textContent = formatCurrency(portfolio.cash);
    document.getElementById('today-pl').textContent = formatCurrency(dailyPl);
    
    const plClass = dailyPl > 0 ? 'text-green-400' : dailyPl < 0 ? 'text-red-400' : 'text-gray-400';
    document.getElementById('today-pl').className = `text-2xl font-semibold ${plClass}`;
};

const renderHoldings = () => {
    const holdingsList = document.getElementById('holdings-list');
    const placeholder = document.getElementById('holdings-placeholder');
    holdingsList.innerHTML = '';
    const tickers = Object.keys(portfolio.stocks);
    
    if (tickers.length === 0) {
        placeholder.classList.remove('hidden');
        holdingsList.appendChild(placeholder);
        return;
    }
    
    tickers.forEach(ticker => {
        const stock = portfolio.stocks[ticker];
        const currentPrice = livePrices[ticker]?.c || stock.purchasePrice;
        const currentValue = stock.quantity * currentPrice;
        const purchaseValue = stock.quantity * stock.purchasePrice;
        const gainLoss = currentValue - purchaseValue;
        const gainLossPercent = purchaseValue > 0 ? (gainLoss / purchaseValue) * 100 : 0;
        const colorClass = gainLoss >= 0 ? 'text-green-400' : 'text-red-400';
        
        const holdingEl = document.createElement('div');
        holdingEl.className = 'bg-gray-800 p-4 rounded-lg grid grid-cols-2 sm:grid-cols-4 gap-4 items-center shadow-md transition-all duration-300 hover:bg-gray-700';
        holdingEl.innerHTML = `
            <div>
                <p class="font-bold text-lg text-white ticker-symbol">${ticker}</p>
                <p class="text-sm text-gray-400">${stock.quantity} Shares</p>
            </div>
            <div class="text-right sm:text-left">
                <p class="font-semibold text-lg text-white">${formatCurrency(currentValue)}</p>
                <p class="text-sm ${colorClass}">${formatCurrency(gainLoss)} (${gainLossPercent.toFixed(2)}%)</p>
            </div>
            <div class="hidden sm:block">
                <p class="text-sm text-gray-400">Avg. Cost</p>
                <p class="font-medium text-white">${formatCurrency(stock.purchasePrice)}</p>
            </div>
            <div class="hidden sm:block">
                <p class="text-sm text-gray-400">Current Price</p>
                <p class="font-medium text-white">${formatCurrency(currentPrice)}</p>
            </div>
        `;
        holdingsList.appendChild(holdingEl);
    });
};

const handleTrade = async (type) => {
    const ticker = document.getElementById('ticker').value.trim().toUpperCase();
    const quantity = parseInt(document.getElementById('quantity').value);
    const feedback = document.getElementById('trade-feedback');
    
    if (!ticker || !quantity || quantity <= 0) {
        showModal('Invalid Input', 'Please enter a valid ticker and positive quantity.');
        return;
    }
    
    feedback.textContent = `Fetching price for ${ticker}...`;
    feedback.classList.remove('text-red-400', 'text-green-400');
    
    const quote = await getStockQuote(ticker);
    if (!quote) {
        showModal('Trade Error', `Could not find stock "${ticker}".`);
        feedback.textContent = `Invalid ticker: ${ticker}`;
        feedback.classList.add('text-red-400');
        return;
    }
    
    const price = quote.c;
    
    if (type === 'buy') {
        const totalCost = price * quantity;
        if (totalCost > portfolio.cash) {
            showModal('Insufficient Funds', `Need ${formatCurrency(totalCost)} but only have ${formatCurrency(portfolio.cash)}.`);
            feedback.textContent = 'Not enough cash.';
            return;
        }
        
        portfolio.cash -= totalCost;
        const existing = portfolio.stocks[ticker];
        if (existing) {
            const newTotalValue = (existing.purchasePrice * existing.quantity) + totalCost;
            existing.quantity += quantity;
            existing.purchasePrice = newTotalValue / existing.quantity;
        } else {
            portfolio.stocks[ticker] = { quantity, purchasePrice: price };
        }
        livePrices[ticker] = quote;
        feedback.textContent = `Bought ${quantity} ${ticker}.`;
    } else {
        if (!portfolio.stocks[ticker] || portfolio.stocks[ticker].quantity < quantity) {
            showModal('Invalid Sale', `Don't own enough ${ticker} shares.`);
            return;
        }
        
        portfolio.cash += price * quantity;
        portfolio.stocks[ticker].quantity -= quantity;
        if (portfolio.stocks[ticker].quantity === 0) {
            delete portfolio.stocks[ticker];
        }
        feedback.textContent = `Sold ${quantity} ${ticker}.`;
    }
    
    saveState();
    updateAllUI();
    feedback.classList.add('text-green-400');
    document.getElementById('ticker').value = '';
    document.getElementById('quantity').value = '';
};

// Research functions
const handleResearch = async () => {
    const ticker = document.getElementById('research-ticker-input').value.trim().toUpperCase();
    if (!ticker) {
        showModal('Invalid Input', 'Please enter a ticker to research.');
        return;
    }
    
    document.getElementById('research-placeholder').classList.add('hidden');
    document.getElementById('research-results').classList.add('hidden');
    document.getElementById('research-loading').classList.remove('hidden');

    try {
        const quote = await getStockQuote(ticker);
        if (!quote) throw new Error('Invalid ticker');
        
        const profile = await getCompanyProfile(ticker);
        const news = await getCompanyNews(ticker);
        
        lastResearched = { ticker, profile, news, quote };

        document.getElementById('research-loading').classList.add('hidden');
        renderCompanyProfile(profile);
        renderCompanyNews(news);
        renderPriceInfo(quote);
        await updateChartForRange('1D');
        document.getElementById('research-results').classList.remove('hidden');
    } catch (error) {
        document.getElementById('research-loading').classList.add('hidden');
        showModal('Research Error', `Could not find data for "${ticker}".`);
        document.getElementById('research-placeholder').classList.remove('hidden');
    }
};

const renderPriceInfo = (quote) => {
    if (!quote) {
        document.getElementById('price-info').innerHTML = '';
        return;
    }
    const change = quote.d;
    const changePercent = quote.dp;
    const colorClass = change >= 0 ? 'text-green-400' : 'text-red-400';
    document.getElementById('price-info').innerHTML = `
        <div class="flex justify-between items-baseline">
            <div>
                <p class="text-3xl font-bold">${formatCurrency(quote.c)}</p>
                <p class="font-semibold ${colorClass}">${formatCurrency(change)} (${changePercent.toFixed(2)}%) Today</p>
            </div>
            <div class="text-right text-sm text-gray-400">
                <p>High: ${formatCurrency(quote.h)}</p>
                <p>Low: ${formatCurrency(quote.l)}</p>
                <p>Prev. Close: ${formatCurrency(quote.pc)}</p>
            </div>
        </div>
    `;
};

const renderStockChart = (candleData, quote) => {
    if (chartInstance) chartInstance.destroy();
    const canvas = document.getElementById('stock-chart');
    if (!candleData || candleData.s !== 'ok' || !candleData.t || candleData.t.length === 0) {
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = '#9ca3af';
        ctx.font = '16px Inter';
        ctx.textAlign = 'center';
        ctx.fillText('Chart data not available', canvas.width / 2, canvas.height / 2);
        return;
    }

    const labels = candleData.t.map(ts => new Date(ts * 1000));
    const dataPoints = candleData.c;
    const prevClose = quote.pc;
    const chartColor = dataPoints[dataPoints.length - 1] >= prevClose ? '#22c55e' : '#ef4444';

    const ctx = canvas.getContext('2d');
    chartInstance = new Chart(ctx, {
        type: 'line',
        data: {
            labels: labels,
            datasets: [{
                label: 'Price',
                data: dataPoints,
                borderColor: chartColor,
                backgroundColor: (context) => {
                    const chart = context.chart;
                    const {ctx, chartArea} = chart;
                    if (!chartArea) return null;
                    const gradient = ctx.createLinearGradient(0, chartArea.bottom, 0, chartArea.top);
                    gradient.addColorStop(0, 'rgba(0,0,0,0)');
                    gradient.addColorStop(1, chartColor + '40');
                    return gradient;
                },
                borderWidth: 2,
                pointRadius: 0,
                fill: true,
                tension: 0.1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    mode: 'index',
                    intersect: false,
                    backgroundColor: 'rgba(31, 41, 55, 0.8)',
                    titleColor: '#f9fafb',
                    bodyColor: '#f9fafb',
                    borderColor: '#374151',
                    borderWidth: 1
                }
            },
            scales: {
                x: {
                    type: 'time',
                    time: {
                        unit: 'hour',
                        displayFormats: { hour: 'MMM dd HH:mm' }
                    },
                    grid: { color: 'rgba(255, 255, 255, 0.1)' },
                    ticks: { color: '#9ca3af' }
                },
                y: {
                    grid: { color: 'rgba(255, 255, 255, 0.1)' },
                    ticks: {
                        color: '#9ca3af',
                        callback: function(value) { return '$' + value.toFixed(2); },
                    }
                }
            }
        }
    });
};

const updateChartForRange = async (range) => {
    if (!lastResearched.ticker) return;

    document.querySelectorAll('.range-btn').forEach(btn =>
        btn.classList.toggle('range-btn-active', btn.dataset.range === range)
    );

    const now = Math.floor(Date.now() / 1000);
    let from, resolution;

    switch(range) {
        case '1D':
            resolution = 'D';
            from = now - (24 * 60 * 60);
            break;
        case '5D':
            resolution = 'D';
            from = now - (5 * 24 * 60 * 60);
            break;
        case '1M':
            resolution = 'D';
            from = now - (30 * 24 * 60 * 60);
            break;
        case '6M':
            resolution = 'W';
            from = now - (6 * 30 * 24 * 60 * 60);
            break;
        case '1Y':
            resolution = 'W';
            from = now - (365 * 24 * 60 * 60);
            break;
        default:
            resolution = 'D';
            from = now - (24 * 60 * 60);
    }

    const candleData = await getStockCandles(lastResearched.ticker, resolution, from, now);
    renderStockChart(candleData, lastResearched.quote);
};

const renderCompanyProfile = (profile) => {
    const container = document.getElementById('company-profile');
    if (!profile || !profile.name) {
        container.innerHTML = `<div class="bg-gray-800 p-6 rounded-lg shadow-lg"><p class="text-gray-400">Company profile not available.</p></div>`;
        return;
    }
    container.innerHTML = `
        <div class="bg-gray-800 p-6 rounded-lg shadow-lg">
            <div class="flex items-center mb-4">
                ${profile.logo ? `<img src="${profile.logo}" alt="Logo" class="w-16 h-16 rounded-full mr-4 bg-white" onerror="this.style.display='none'">` : ''}
                <div>
                    <h2 class="text-2xl font-bold text-white">${profile.name} <span class="text-lg font-normal text-gray-400 ticker-symbol">(${profile.ticker || lastResearched.ticker})</span></h2>
                    ${profile.weburl ? `<a href="${profile.weburl}" target="_blank" class="text-sm text-cyan-400 hover:underline">${profile.weburl}</a>` : ''}
                </div>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 text-sm">
                ${profile.finnhubIndustry ? `<div><p class="text-gray-400">Industry</p><p class="font-semibold">${profile.finnhubIndustry}</p></div>` : ''}
                ${profile.marketCapitalization ? `<div><p class="text-gray-400">Market Cap</p><p class="font-semibold">${formatMarketCap(profile.marketCapitalization)}</p></div>` : ''}
                ${profile.ipo ? `<div><p class="text-gray-400">IPO Date</p><p class="font-semibold">${profile.ipo}</p></div>` : ''}
                ${profile.country ? `<div><p class="text-gray-400">Country</p><p class="font-semibold">${profile.country}</p></div>` : ''}
            </div>
        </div>
    `;
};

const renderCompanyNews = (news) => {
    const container = document.getElementById('company-news');
    container.innerHTML = '';
    if (!news || news.length === 0) {
        container.innerHTML = `<p class="text-gray-400 bg-gray-800 p-4 rounded-lg">No recent news found for this stock.</p>`;
        return;
    }
    
    let articlesToRender = news;
    if (filterFreeNews) {
        articlesToRender = news.filter(article =>
            freeNewsSources.some(freeSource =>
                article.source.toLowerCase().includes(freeSource.toLowerCase())
            )
        );
    }
    
    if (articlesToRender.length === 0) {
        container.innerHTML = `<p class="text-gray-400 bg-gray-800 p-4 rounded-lg">No recent ${filterFreeNews ? 'free ' : ''}news found for this stock.</p>`;
        return;
    }
    
    articlesToRender.slice(0, 10).forEach(article => {
        const articleEl = document.createElement('a');
        articleEl.href = article.url;
        articleEl.target = '_blank';
        articleEl.className = 'block bg-gray-800 p-4 rounded-lg hover:bg-gray-700 transition';
        articleEl.innerHTML = `
            <p class="font-semibold text-white mb-1">${article.headline}</p>
            <p class="text-sm text-gray-400">${article.source} - ${new Date(article.datetime * 1000).toLocaleDateString()}</p>
            <p class="text-sm text-gray-300 mt-2">${article.summary}</p>
        `;
        container.appendChild(articleEl);
    });
};

// Core app functions
const updateAllUI = () => {
    updatePortfolioSummary();
    renderHoldings();
    renderWatchlist();
};

const fetchAllLivePrices = async () => {
    updateStatus('Updating prices...', 'bg-yellow-500 animate-pulse');
    const allTickers = [...Object.keys(portfolio.stocks), ...watchlist];
    const uniqueTickers = [...new Set(allTickers)];
    
    if (uniqueTickers.length === 0) {
        updateStatus('Connected', 'bg-green-500');
        return;
    }
    
    for (const ticker of uniqueTickers) {
        const quote = await getStockQuote(ticker);
        if (quote) livePrices[ticker] = quote;
    }
    
    updateAllUI();
    updateStatus('Connected', 'bg-green-500');
};

const initializeApp = async () => {
    if (updateInterval) clearInterval(updateInterval);
    switchView('portfolio');
    await fetchAllLivePrices();
    updateInterval = setInterval(fetchAllLivePrices, 300000);
};

// Event listeners
document.getElementById('save-api-key-btn').addEventListener('click', () => {
    const key = document.getElementById('api-key-input').value.trim();
    if (key) {
        apiKey = key;
        saveState();
        document.getElementById('api-key-section').classList.add('hidden');
        document.getElementById('app-content').classList.remove('hidden');
        initializeApp();
    } else {
        showModal('API Key Required', 'Please enter a valid Finnhub API key.');
    }
});

document.getElementById('buy-btn').addEventListener('click', () => handleTrade('buy'));
document.getElementById('sell-btn').addEventListener('click', () => handleTrade('sell'));

document.getElementById('nav-portfolio').addEventListener('click', () => switchView('portfolio'));
document.getElementById('nav-research').addEventListener('click', () => switchView('research'));
document.getElementById('nav-watchlist').addEventListener('click', () => switchView('watchlist'));

document.getElementById('research-btn').addEventListener('click', handleResearch);
document.getElementById('add-watchlist-btn').addEventListener('click', addToWatchlist);
document.getElementById('modal-close-btn').addEventListener('click', hideModal);

document.getElementById('free-news-toggle').addEventListener('change', (e) => {
    filterFreeNews = e.target.checked;
    saveState();
    if (!document.getElementById('research-results').classList.contains('hidden')) {
        renderCompanyNews(lastResearched.news);
    }
});

document.getElementById('range-selector').addEventListener('click', (e) => {
    if (e.target.matches('.range-btn')) {
        const range = e.target.dataset.range;
        updateChartForRange(range);
    }
});

// Keyboard shortcuts
document.getElementById('research-ticker-input').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleResearch();
});

document.getElementById('watchlist-ticker-input').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') addToWatchlist();
});

document.getElementById('ticker').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') document.getElementById('quantity').focus();
});

document.getElementById('quantity').addEventListener('keypress', (e) => {
    if (e.key === 'Enter') handleTrade('buy');
});

// Global function for watchlist removal
window.removeFromWatchlist = removeFromWatchlist;

// Initialize
document.addEventListener('DOMContentLoaded', () => {
    lucide.createIcons();
    loadState();
    updateAllUI();
});
</script>
</body>
</html>