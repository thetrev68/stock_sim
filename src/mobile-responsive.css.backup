/* Mobile Responsive Styles - Complete file for simulation detail view optimizations */

/* ========================================
   GLOBAL TYPOGRAPHY & CONTRAST IMPROVEMENTS
   ======================================== */

/* Apply better contrast across all screen sizes */
.text-gray-400 {
    color: #d1d5db !important; /* Much better contrast than default */
}

.text-gray-500 {
    color: #9ca3af !important; /* Better than default gray-500 */
}

/* Improve small text readability everywhere */
.text-sm {
    font-weight: 500 !important; /* Slightly bolder for readability */
    color: #e5e7eb !important; /* Better contrast */
}

.text-xs {
    font-weight: 500 !important;
    color: #d1d5db !important;
}

/* Enhanced card definition */
.bg-gray-800 {
    border: 1px solid #374151 !important;
}

/* Better button contrast */
button {
    font-weight: 600 !important;
}

/* ========================================
   MOBILE-SPECIFIC OPTIMIZATIONS
   ======================================== */

/* Auth View Mobile Fixes */
.auth-view {
    padding: 1rem;
}

.auth-view .bg-gray-800 {
    padding: 1.5rem !important;
    margin: 0 1rem;
    max-width: calc(100vw - 2rem) !important;
}

/* Responsive breakpoints for auth container */
@media (min-width: 640px) {
    .auth-view {
        padding: 2rem;
    }
    
    .auth-view .bg-gray-800 {
        padding: 2rem !important;
        margin: 0 auto;
        max-width: 28rem !important;
    }
}

/* Enhanced mobile form inputs */
.auth-view input {
    font-size: 16px !important; /* Prevent zoom on iOS */
    min-height: 44px;
}

/* Mobile-optimized buttons */
.auth-view button {
    min-height: 44px;
    font-size: 1rem;
    padding: 0.875rem 1.5rem;
}

/* Viewport optimization */
html {
    overflow-x: hidden;
}

body {
    max-width: 100vw;
    overflow-x: hidden;
}

/* ========================================
   NAVIGATION RESPONSIVE STYLES
   ======================================== */

@media (max-width: 768px) {
    .mobile-hidden {
        display: none !important;
    }
    
    .mobile-stack {
        flex-direction: column !important;
    }
    
    .mobile-full-width {
        width: 100% !important;
    }
    
    .mobile-p-4 {
        padding: 1rem !important;
    }
    
    /* Dashboard mobile typography */
    .dashboard-view .text-sm {
        font-size: 0.875rem !important;
    }
    
    .dashboard-view .text-xs {
        font-size: 0.8125rem !important;
    }
    
    .dashboard-view button {
        font-size: 0.9rem !important;
        min-height: 44px !important;
    }
}

/* ========================================
   TOUCH-FRIENDLY ELEMENTS
   ======================================== */

@media (hover: none) and (pointer: coarse) {
    button, .clickable {
        min-height: 44px;
        min-width: 44px;
    }
    
    button:hover {
        transform: none;
    }
}

/* ========================================
   TABLE RESPONSIVENESS
   ======================================== */

.mobile-scroll-table {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}

@media (max-width: 768px) {
    .mobile-scroll-table table {
        min-width: 600px;
    }
    
    .mobile-hide-column {
        display: none;
    }
}

/* ========================================
   MODAL OPTIMIZATIONS
   ======================================== */

@media (max-width: 768px) {
    .modal-content {
        margin: 1rem !important;
        max-height: calc(100vh - 2rem) !important;
        border-radius: 0.5rem !important;
    }
    
    .modal-body {
        max-height: calc(100vh - 8rem);
        overflow-y: auto;
    }
}

/* ========================================
   ANIMATIONS & LOADING STATES
   ======================================== */

.loading-spinner {
    animation: spin 1s linear infinite;
}

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.error-message {
    word-break: break-word;
    hyphens: auto;
}

/* Focus states for accessibility */
button:focus,
.nav-link:focus {
    outline: 2px solid #22d3ee !important;
    outline-offset: 2px !important;
}

/* ========================================
   Simulation Detail View Mobile Fixes
   ======================================== */

/* Header Component Mobile Optimization */
@media (max-width: 768px) {
    .header-component {
        /* Force column layout and better spacing */
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 1rem !important;
        margin-bottom: 1.5rem !important;
    }
    
    .header-component h1 {
        font-size: 1.875rem !important; /* Reduce from 3xl to xl */
        line-height: 1.2 !important;
    }
    
    .header-component p {
        font-size: 0.875rem !important;
        margin-bottom: 0.5rem !important;
    }
    
    /* User menu mobile layout */
    .header-component #user-menu {
        width: 100% !important;
    }
    
    .header-component #user-menu > div {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 0.5rem !important;
        width: 100% !important;
    }
    
    .header-component #user-email {
        font-size: 0.8125rem !important;
        word-break: break-all !important;
    }
    
    .header-component #sign-out-btn {
        font-size: 0.8125rem !important;
        align-self: flex-end !important;
    }
}

/* Simulation Tab Buttons Mobile Fix */
@media (max-width: 768px) {
    /* Tab container - enable horizontal scrolling */
    .bg-gray-800 > .flex.border-b {
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
        scroll-behavior: smooth !important;
        border-bottom: 1px solid #374151 !important;
    }
    
    /* Individual tab buttons */
    .tab-btn {
        flex-shrink: 0 !important; /* Prevent shrinking */
        min-width: 120px !important; /* Ensure minimum width */
        padding: 0.75rem 1rem !important; /* Reduce padding */
        font-size: 0.875rem !important; /* Smaller text */
        white-space: nowrap !important; /* Prevent text wrapping */
    }
    
    /* Add scroll indicator */
    .bg-gray-800 > .flex.border-b {
        position: relative;
    }
    
    .bg-gray-800 > .flex.border-b::after {
        content: "";
        position: absolute;
        right: 0;
        top: 0;
        width: 20px;
        height: 100%;
        background: linear-gradient(to right, transparent, rgba(31, 41, 55, 0.9));
        pointer-events: none;
        z-index: 1;
    }
}

/* Simulation Header Section Mobile */
@media (max-width: 768px) {
    /* Main simulation header */
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 {
        padding: 1rem !important;
        margin-bottom: 1.5rem !important;
    }
    
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 h1 {
        font-size: 1.5rem !important; /* Reduce title size */
        margin-bottom: 0.5rem !important;
    }
    
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 p {
        font-size: 0.875rem !important;
        margin-bottom: 0.75rem !important;
    }
    
    /* Status and participant info */
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 .flex.items-center.gap-4 {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 0.5rem !important;
    }
    
    /* Action buttons row */
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 .flex.gap-3 {
        flex-direction: column !important;
        gap: 0.75rem !important;
        width: 100% !important;
    }
    
    /* Individual action buttons */
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 .flex.gap-3 button {
        width: 100% !important;
        padding: 0.75rem 1rem !important;
        font-size: 0.875rem !important;
        justify-content: center !important;
    }
    
    /* Button text and icons */
    .bg-gray-800.p-6.rounded-lg.shadow-lg.mb-8 .flex.gap-3 button svg {
        width: 1rem !important;
        height: 1rem !important;
    }
}

/* Stats Cards Mobile (Your Rank, Portfolio Value, etc.) */
@media (max-width: 768px) {
    /* Stats grid - force single column */
    .grid.grid-cols-1.md\\:grid-cols-3 {
        grid-template-columns: 1fr !important;
        gap: 1rem !important;
        margin-bottom: 1.5rem !important;
    }
    
    /* Individual stat cards */
    .grid.grid-cols-1.md\\:grid-cols-3 .bg-gray-800 {
        padding: 1rem !important;
    }
    
    .grid.grid-cols-1.md\\:grid-cols-3 .text-3xl {
        font-size: 1.5rem !important;
    }
    
    .grid.grid-cols-1.md\\:grid-cols-3 .text-sm {
        font-size: 0.8125rem !important;
    }
}

/* ========================================
   TABLE & LEADERBOARD MOBILE OPTIMIZATIONS
   ======================================== */

/* Leaderboard and Members Tables */
@media (max-width: 768px) {
    /* Table container - enable horizontal scroll */
    .table-container,
    #leaderboard-table-container,
    #members-table-container,
    #portfolio-table-container,
    #rankings-table-container {
        overflow-x: auto !important;
        -webkit-overflow-scrolling: touch !important;
        border-radius: 0.5rem !important;
        border: 1px solid #374151 !important;
    }
    
    /* Tables - set minimum width for scroll */
    .table-container table,
    #leaderboard-table-container table,
    #members-table-container table,
    #portfolio-table-container table,
    #rankings-table-container table {
        min-width: 700px !important;
        font-size: 0.875rem !important;
    }
    
    /* Table headers - smaller font */
    .table-container th,
    #leaderboard-table-container th,
    #members-table-container th,
    #portfolio-table-container th,
    #rankings-table-container th {
        padding: 0.75rem 1rem !important;
        font-size: 0.75rem !important;
        white-space: nowrap !important;
    }
    
    /* Table cells - compact padding */
    .table-container td,
    #leaderboard-table-container td,
    #members-table-container td,
    #portfolio-table-container td,
    #rankings-table-container td {
        padding: 0.75rem 1rem !important;
        font-size: 0.8125rem !important;
    }
    
    /* Hide less important columns on mobile */
    .mobile-hide-column {
        display: none !important;
    }
    
    /* Member status badges - smaller */
    .status-badge {
        font-size: 0.6875rem !important;
        padding: 0.125rem 0.375rem !important;
    }
    
    /* Action buttons in tables */
    .table-action-btn {
        padding: 0.375rem 0.5rem !important;
        font-size: 0.75rem !important;
        min-height: 32px !important;
    }
}

/* ========================================
   PORTFOLIO TAB MOBILE OPTIMIZATIONS
   ======================================== */

@media (max-width: 768px) {
    /* Portfolio summary cards */
    .portfolio-summary {
        grid-template-columns: 1fr !important;
        gap: 1rem !important;
    }
    
    /* Portfolio stats */
    .portfolio-stats .text-2xl {
        font-size: 1.25rem !important;
    }
    
    .portfolio-stats .text-4xl {
        font-size: 2rem !important;
    }
    
    /* Holdings grid */
    .holdings-grid {
        grid-template-columns: 1fr !important;
        gap: 0.75rem !important;
    }
    
    /* Individual holding cards */
    .holding-card {
        padding: 1rem !important;
    }
    
    .holding-card .text-lg {
        font-size: 1rem !important;
    }
    
    .holding-card .text-sm {
        font-size: 0.8125rem !important;
    }
}

/* ========================================
   ACTIVITY FEED MOBILE OPTIMIZATIONS
   ======================================== */

@media (max-width: 768px) {
    /* Activity feed container */
    #activity-feed {
        padding: 1rem !important;
    }
    
    /* Activity items */
    .activity-item {
        padding: 0.75rem !important;
        margin-bottom: 0.75rem !important;
    }
    
    /* Activity item layout - stack vertically */
    .activity-item .flex {
        flex-direction: column !important;
        align-items: flex-start !important;
        gap: 0.5rem !important;
    }
    
    .activity-item .flex .justify-between {
        width: 100% !important;
        justify-content: space-between !important;
    }
    
    /* Activity text */
    .activity-item .text-sm {
        font-size: 0.8125rem !important;
        line-height: 1.4 !important;
    }
    
    /* Activity timestamps */
    .activity-timestamp {
        font-size: 0.75rem !important;
        color: #9ca3af !important;
    }
    
    /* Trade amounts in activity */
    .activity-amount {
        font-size: 0.875rem !important;
        font-weight: 600 !important;
    }
}

/* ========================================
   MODAL CONTENT MOBILE OPTIMIZATIONS
   ======================================== */

@media (max-width: 768px) {
    /* Trade modal specific */
    .trade-modal {
        margin: 0.5rem !important;
        max-height: calc(100vh - 1rem) !important;
        width: calc(100vw - 1rem) !important;
    }
    
    /* Member management modal */
    .member-modal {
        margin: 1rem !important;
        max-height: calc(100vh - 2rem) !important;
    }
    
    /* Settings modal */
    .settings-modal {
        margin: 0.5rem !important;
        max-height: calc(100vh - 1rem) !important;
        width: calc(100vw - 1rem) !important;
    }
    
    /* Modal form fields */
    .modal-form input,
    .modal-form select,
    .modal-form textarea {
        font-size: 1rem !important; /* Prevent zoom on iOS */
        padding: 0.75rem !important;
        min-height: 44px !important;
    }
    
    /* Modal buttons */
    .modal-buttons {
        flex-direction: column !important;
        gap: 0.75rem !important;
    }
    
    .modal-buttons button {
        width: 100% !important;
        justify-content: center !important;
        min-height: 44px !important;
    }
}

/* General Mobile Content Padding */
@media (max-width: 768px) {
    /* Tab content areas */
    .tab-content .p-6 {
        padding: 1rem !important;
    }
    
    /* Generic content containers */
    .bg-gray-800.p-6 {
        padding: 1rem !important;
    }
    
    /* Reduce large gaps */
    .gap-8 {
        gap: 1rem !important;
    }
    
    .gap-6 {
        gap: 0.75rem !important;
    }
    
    /* Make sure text is readable */
    .text-3xl {
        font-size: 1.5rem !important;
    }
    
    .text-2xl {
        font-size: 1.25rem !important;
    }
    
    .text-xl {
        font-size: 1.125rem !important;
    }
}

/* ========================================
   SIMULATION-SPECIFIC MOBILE FIXES
   ======================================== */

@media (max-width: 768px) {
    /* Simulation view container */
    .simulation-view {
        padding: 1rem !important;
    }
    
    /* Tab content wrapper */
    .simulation-tabs-content {
        margin-top: 1rem !important;
    }
    
    /* Error states */
    .error-container {
        margin: 1rem !important;
        padding: 1rem !important;
    }
    
    /* Loading states */
    .loading-container {
        padding: 2rem 1rem !important;
    }
    
    /* Empty states */
    .empty-state {
        padding: 2rem 1rem !important;
    }
    
    .empty-state .text-lg {
        font-size: 1rem !important;
    }
    
    .empty-state .text-base {
        font-size: 0.875rem !important;
    }
}

/* ========================================
   ENHANCED MOBILE BUTTON STYLES
   ======================================== */

@media (max-width: 768px) {
    /* Primary action buttons */
    .btn-primary {
        min-height: 44px !important;
        padding: 0.75rem 1.5rem !important;
        font-size: 0.9375rem !important;
        font-weight: 600 !important;
    }
    
    /* Secondary buttons */
    .btn-secondary {
        min-height: 44px !important;
        padding: 0.6875rem 1.25rem !important;
        font-size: 0.875rem !important;
    }
    
    /* Icon buttons */
    .btn-icon {
        min-width: 44px !important;
        min-height: 44px !important;
        padding: 0.6875rem !important;
    }
    
    /* Button groups */
    .btn-group {
        flex-direction: column !important;
        gap: 0.5rem !important;
        width: 100% !important;
    }
    
    .btn-group button {
        width: 100% !important;
        justify-content: center !important;
    }
}

/* ========================================
   ACCESSIBILITY & INTERACTION IMPROVEMENTS
   ======================================== */

/* Touch target improvements */
@media (hover: none) and (pointer: coarse) {
    /* Ensure all interactive elements meet minimum touch target size */
    button,
    .clickable,
    .tab-btn,
    .nav-link,
    input[type="checkbox"],
    input[type="radio"],
    select {
        min-height: 44px !important;
        min-width: 44px !important;
    }
    
    /* Remove hover effects on touch devices */
    button:hover,
    .clickable:hover,
    .tab-btn:hover,
    .nav-link:hover {
        transform: none !important;
        box-shadow: none !important;
    }
    
    /* Add active states for better feedback */
    button:active,
    .clickable:active,
    .tab-btn:active {
        transform: scale(0.98) !important;
        transition: transform 0.1s ease !important;
    }
}

/* ========================================
   PERFORMANCE OPTIMIZATIONS
   ======================================== */

/* Reduce motion for users who prefer it */
@media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
    }
}

/* Hardware acceleration for smooth scrolling */
.mobile-scroll-table,
.tab-content,
.modal-content {
    transform: translateZ(0);
    -webkit-transform: translateZ(0);
}

/* ========================================
   MOBILE NAVIGATION IMPROVEMENTS (FOR SIMULATION VIEW)
   ======================================== */

@media (max-width: 768px) {
    /* Back button in simulation view */
    .back-to-dashboard {
        position: sticky !important;
        top: 0 !important;
        z-index: 10 !important;
        background: rgba(17, 24, 39, 0.95) !important;
        backdrop-filter: blur(8px) !important;
        padding: 1rem !important;
        margin: -1rem -1rem 1rem -1rem !important;
        border-bottom: 1px solid #374151 !important;
    }
    
    .back-to-dashboard button {
        width: 100% !important;
        justify-content: flex-start !important;
        gap: 0.75rem !important;
        font-size: 0.9375rem !important;
    }
}

/* ========================================
   FINAL POLISH & EDGE CASES
   ======================================== */

@media (max-width: 768px) {
    /* Prevent horizontal scroll */
    body {
        overflow-x: hidden !important;
    }
    
    /* Ensure containers don't exceed viewport */
    .container,
    .max-w-7xl,
    .max-w-6xl,
    .max-w-5xl {
        max-width: calc(100vw - 2rem) !important;
        margin-left: 1rem !important;
        margin-right: 1rem !important;
    }
    
    /* Better spacing for small screens */
    .space-y-8 > * + * {
        margin-top: 1.5rem !important;
    }
    
    .space-y-6 > * + * {
        margin-top: 1rem !important;
    }
    
    /* Improved card spacing */
    .card-grid {
        grid-template-columns: 1fr !important;
        gap: 1rem !important;
    }
    
    /* Better text contrast on mobile */
    .text-gray-400 {
        color: #d1d5db !important;
    }
    
    .text-gray-500 {
        color: #9ca3af !important;
    }
}