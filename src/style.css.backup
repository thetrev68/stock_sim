@import "tailwindcss";

:root {
  font-family: system-ui, Avenir, Helvetica, Arial, sans-serif;
  line-height: 1.5;
  font-weight: 400;

  color-scheme: light dark;
  color: rgba(255, 255, 255, 0.87);
  background-color: #242424;

  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

a {
  font-weight: 500;
  color: #646cff;
  text-decoration: inherit;
}
a:hover {
  color: #535bf2;
}

body {
  margin: 0;
  min-width: 320px;
  min-height: 100vh;
  background-color: #1f2937;
}

h1 {
  font-size: 3.2em;
  line-height: 1.1;
}

#app {
  max-width: none;
  margin: 0;
  padding: 0.5rem;
  text-align: left;
  min-width: 100vw;
}

/* Responsive app container */
@media (min-width: 640px) {
    #app {
        padding: 1rem;
        max-width: 640px;
        margin: 0 auto;
    }
}

@media (min-width: 1024px) {
    #app {
        padding: 2rem;
        max-width: 1280px;
    }
}

.logo {
  height: 6em;
  padding: 1.5em;
  will-change: filter;
  transition: filter 300ms;
}
.logo:hover {
  filter: drop-shadow(0 0 2em #646cffaa);
}
.logo.vanilla:hover {
  filter: drop-shadow(0 0 2em #f7df1eaa);
}

.card {
  padding: 2em;
}

.read-the-docs {
  color: #888;
}

button {
  border-radius: 8px;
  border: 1px solid transparent;
  padding: 0.6em 1.2em;
  font-size: 1em;
  font-weight: 500;
  font-family: inherit;
  background-color: #1a1a1a;
  cursor: pointer;
  transition: border-color 0.25s;
}
button:hover {
  border-color: #646cff;
}
button:focus,
button:focus-visible {
  outline: 4px auto -webkit-focus-ring-color;
}

@media (prefers-color-scheme: light) {
  :root {
    color: #213547;
    background-color: #ffffff;
  }
  a:hover {
    color: #747bff;
  }
  button {
    background-color: #f9f9f9;
  }
}

/* ========================================
   MOBILE & RESPONSIVE ENHANCEMENTS
   ======================================== */

/* Better contrast for readability (all screen sizes) */
.text-gray-400 {
    color: #d1d5db !important;
}

.text-gray-500 {
    color: #9ca3af !important;
}

.text-sm {
    font-weight: 500 !important;
    color: #e5e7eb !important;
}

.text-xs {
    font-weight: 500 !important;
    color: #d1d5db !important;
}

.bg-gray-800 {
    border: 1px solid #374151 !important;
}

button {
    font-weight: 600 !important;
}

/* Auth View Mobile Fixes */
.auth-view {
    padding: 1rem;
}

.auth-view .bg-gray-800 {
    padding: 1.5rem !important;
    margin: 0 1rem;
    max-width: calc(100vw - 2rem) !important;
}

@media (min-width: 640px) {
    .auth-view {
        padding: 2rem;
    }
    
    .auth-view .bg-gray-800 {
        padding: 2rem !important;
        margin: 0 auto;
        max-width: 28rem !important;
    }
}

.auth-view input {
    font-size: 16px !important;
    min-height: 44px;
}

.auth-view button {
    min-height: 44px;
    font-size: 1rem;
    padding: 0.875rem 1.5rem;
}

/* Viewport optimization */
html {
    overflow-x: hidden;
}

body {
    max-width: 100vw;
    overflow-x: hidden;
}

/* Navigation Mobile Fixes */
@media (max-width: 480px) {
    nav.flex {
        margin-left: -0.5rem !important;
        margin-right: -0.5rem !important;
        padding-left: 0.5rem !important;
        padding-right: 0.5rem !important;
        margin-bottom: 1.5rem !important;
        scroll-behavior: smooth;
        -webkit-overflow-scrolling: touch;
    }
    
    nav.flex .nav-link {
        flex-shrink: 0 !important;
        padding: 0.75rem 1rem !important;
        font-size: 0.875rem !important;
        min-width: auto !important;
        white-space: nowrap !important;
    }
    
    nav.flex {
        position: relative;
    }
    
    nav.flex::after {
        content: "";
        position: absolute;
        right: 0;
        top: 0;
        width: 20px;
        height: 100%;
        background: linear-gradient(to right, transparent, rgba(17, 24, 39, 0.9));
        pointer-events: none;
        z-index: 1;
    }
}

@media (min-width: 481px) and (max-width: 768px) {
    nav.flex .nav-link {
        padding: 0.75rem 1.25rem !important;
        font-size: 0.9rem !important;
    }
}

@media (min-width: 769px) {
    nav.flex {
        justify-content: center !important;
        margin: 0 auto 2rem auto !important;
        max-width: fit-content !important;
    }
    
    nav.flex .nav-link {
        padding: 0.75rem 1.5rem !important;
        font-size: 1rem !important;
    }
    
    nav.flex::after {
        display: none !important;
    }
}

/* Mobile utility classes and touch-friendly elements */
@media (max-width: 768px) {
    .mobile-hidden {
        display: none !important;
    }
    
    .mobile-stack {
        flex-direction: column !important;
    }
    
    .mobile-full-width {
        width: 100% !important;
    }
    
    .dashboard-view .text-sm {
        font-size: 0.875rem !important;
    }
    
    .dashboard-view .text-xs {
        font-size: 0.8125rem !important;
    }
    
    .dashboard-view button {
        font-size: 0.9rem !important;
        min-height: 44px !important;
    }
}

@media (hover: none) and (pointer: coarse) {
    button, .clickable {
        min-height: 44px;
        min-width: 44px;
    }
    
    button:hover {
        transform: none;
    }
}

/* Table responsiveness */
.mobile-scroll-table {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}

@media (max-width: 768px) {
    .mobile-scroll-table table {
        min-width: 600px;
    }
    
    .mobile-hide-column {
        display: none;
    }
}

/* Modal mobile optimization */
@media (max-width: 768px) {
    .modal-content {
        margin: 1rem !important;
        max-height: calc(100vh - 2rem) !important;
        border-radius: 0.5rem !important;
    }
    
    .modal-body {
        max-height: calc(100vh - 8rem);
        overflow-y: auto;
    }
}

/* Focus states for accessibility */
button:focus,
.nav-link:focus {
    outline: 2px solid #22d3ee !important;
    outline-offset: 2px !important;
}