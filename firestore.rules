rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    match /Users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null; // Allow reading other users for admin purposes
    }
    
    // Simulations: Read if authenticated, write if creator or admin
    match /simulations/{simulationId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && 
        (resource.data.createdBy == request.auth.uid || 
         get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.systemRole in ['admin', 'super_admin']);
    }
    
    // Simulation members - full access for authenticated users
    match /simulationMembers/{memberId} {
      allow read, write: if request.auth != null;
    }
    
    // Portfolios: Users can access their own portfolios
    match /portfolios/{portfolioId} {
      allow read, write: if request.auth != null && 
        portfolioId.matches('.*' + request.auth.uid + '.*');
    }
    
    // Simulation activities - full access for authenticated users
    match /simulationActivities/{activityId} {
      allow read, write: if request.auth != null;
    }
    
    // 🚀 SIMPLIFIED: Cached leaderboards - full access for authenticated users
    match /cachedLeaderboards/{leaderboardId} {
      allow read, write: if request.auth != null;
    }
    
    // Archives - full access for authenticated users
    match /simulationArchives/{archiveId} {
      allow read, write: if request.auth != null;
    }
    
    // 🚀 CATCH-ALL: Allow any other collections for authenticated users (temporary)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}