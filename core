<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paper Trader</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        .ticker-symbol {
            font-variant-caps: all-small-caps;
        }
    </style>
</head>
<body class="bg-gray-900 text-white antialiased">

    <div id="app" class="max-w-4xl mx-auto p-4 sm:p-6 lg:p-8">

        <!-- Header -->
        <header class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold text-cyan-400">Paper Trader</h1>
                <p class="text-gray-400">Invest with zero risk.</p>
            </div>
            <div id="status-indicator" class="flex items-center space-x-2">
                <div class="w-3 h-3 rounded-full bg-gray-500 animate-pulse"></div>
                <span class="text-gray-400 text-sm">Connecting...</span>
            </div>
        </header>

        <!-- API Key Input -->
        <div id="api-key-section" class="bg-gray-800 p-6 rounded-lg mb-8 shadow-lg border border-gray-700">
            <h2 class="text-xl font-semibold mb-3">Setup Required</h2>
            <p class="text-gray-400 mb-4">To get live stock prices, you need a free API key from Finnhub.io.</p>
            <div class="flex flex-col sm:flex-row gap-4">
                <input type="text" id="api-key-input" placeholder="Paste your Finnhub API key here" class="flex-grow bg-gray-700 text-white placeholder-gray-500 rounded-md px-4 py-2 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500 transition">
                <button id="save-api-key-btn" class="bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-6 rounded-md transition-colors duration-300">Save & Connect</button>
            </div>
             <p class="text-xs text-gray-500 mt-3">
                <a href="https://finnhub.io/register" target="_blank" class="underline hover:text-cyan-400">Click here to get your free key.</a> Your key is saved only in your browser.
            </p>
        </div>

        <!-- Main Content (Hidden until API key is set) -->
        <main id="main-content" class="hidden">

            <!-- Portfolio Summary -->
            <section id="portfolio-summary" class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                    <h3 class="text-sm font-medium text-gray-400">Portfolio Value</h3>
                    <p id="total-value" class="text-2xl font-semibold text-white">$0.00</p>
                </div>
                <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                    <h3 class="text-sm font-medium text-gray-400">Stock Holdings</h3>
                    <p id="stocks-value" class="text-2xl font-semibold text-white">$0.00</p>
                </div>
                <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                    <h3 class="text-sm font-medium text-gray-400">Available Cash</h3>
                    <p id="cash-value" class="text-2xl font-semibold text-green-400">$0.00</p>
                </div>
                 <div class="bg-gray-800 p-5 rounded-lg shadow-md">
                    <h3 class="text-sm font-medium text-gray-400">Today's P/L</h3>
                    <p id="today-pl" class="text-2xl font-semibold text-gray-500">$0.00</p>
                </div>
            </section>

            <!-- Trade Form & Holdings -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                
                <!-- Trade Form -->
                <div class="lg:col-span-1">
                    <div class="bg-gray-800 p-6 rounded-lg shadow-lg sticky top-8">
                        <h2 class="text-xl font-semibold mb-4">Make a Trade</h2>
                        <div class="space-y-4">
                            <div>
                                <label for="ticker" class="block text-sm font-medium text-gray-300 mb-1">Ticker Symbol</label>
                                <input type="text" id="ticker" name="ticker" class="w-full bg-gray-700 text-white rounded-md px-3 py-2 border border-gray-600 uppercase focus:outline-none focus:ring-2 focus:ring-cyan-500" placeholder="e.g., AAPL, TSLA">
                            </div>
                            <div>
                                <label for="quantity" class="block text-sm font-medium text-gray-300 mb-1">Quantity</label>
                                <input type="number" id="quantity" name="quantity" min="1" class="w-full bg-gray-700 text-white rounded-md px-3 py-2 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-cyan-500" placeholder="e.g., 10">
                            </div>
                            <div class="flex gap-4">
                                <button id="buy-btn" class="w-full bg-green-600 hover:bg-green-500 text-white font-bold py-2 rounded-md transition-colors duration-300">Buy</button>
                                <button id="sell-btn" class="w-full bg-red-600 hover:bg-red-500 text-white font-bold py-2 rounded-md transition-colors duration-300">Sell</button>
                            </div>
                        </div>
                        <div id="trade-feedback" class="mt-4 text-sm text-center">&nbsp;</div>
                    </div>
                </div>

                <!-- Holdings -->
                <div class="lg:col-span-2">
                    <h2 class="text-xl font-semibold mb-4 text-gray-300">My Holdings</h2>
                    <div id="holdings-list" class="space-y-4">
                        <!-- Example of a holding item -->
                        <div class="bg-gray-800 p-4 rounded-lg flex items-center justify-between shadow-md hidden" id="holdings-placeholder">
                            <p class="text-center text-gray-400 w-full">You don't own any stocks yet. Buy one to get started!</p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        
        <!-- Message Modal -->
        <div id="message-modal" class="fixed inset-0 bg-black bg-opacity-70 flex items-center justify-center hidden z-50">
            <div class="bg-gray-800 rounded-lg p-8 max-w-sm w-full shadow-2xl border border-gray-700">
                <h3 id="modal-title" class="text-xl font-bold text-white mb-4">Alert</h3>
                <p id="modal-message" class="text-gray-300 mb-6">This is a sample message.</p>
                <button id="modal-close-btn" class="w-full bg-cyan-600 hover:bg-cyan-500 text-white font-bold py-2 px-4 rounded-md transition-colors duration-300">Close</button>
            </div>
        </div>

    </div>

    <script>
        // --- DOM Elements ---
        const apiKeySection = document.getElementById('api-key-section');
        const apiKeyInput = document.getElementById('api-key-input');
        const saveApiKeyBtn = document.getElementById('save-api-key-btn');
        const mainContent = document.getElementById('main-content');
        const statusIndicator = document.getElementById('status-indicator');
        
        const totalValueEl = document.getElementById('total-value');
        const stocksValueEl = document.getElementById('stocks-value');
        const cashValueEl = document.getElementById('cash-value');
        const todayPlEl = document.getElementById('today-pl');
        
        const tickerInput = document.getElementById('ticker');
        const quantityInput = document.getElementById('quantity');
        const buyBtn = document.getElementById('buy-btn');
        const sellBtn = document.getElementById('sell-btn');
        const tradeFeedback = document.getElementById('trade-feedback');
        
        const holdingsList = document.getElementById('holdings-list');
        const holdingsPlaceholder = document.getElementById('holdings-placeholder');

        const messageModal = document.getElementById('message-modal');
        const modalTitle = document.getElementById('modal-title');
        const modalMessage = document.getElementById('modal-message');
        const modalCloseBtn = document.getElementById('modal-close-btn');

        // --- State Management ---
        let apiKey = '';
        let portfolio = {
            cash: 10000,
            stocks: {}, // e.g., { AAPL: { quantity: 10, purchasePrice: 150 }, ... }
        };
        // This will store current prices fetched from the API
        let livePrices = {};
        let updateInterval;

        // --- Utility Functions ---
        const formatCurrency = (amount) => {
            return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amount);
        };
        
        const showModal = (title, message) => {
            modalTitle.textContent = title;
            modalMessage.textContent = message;
            messageModal.classList.remove('hidden');
        };

        const hideModal = () => {
            messageModal.classList.add('hidden');
        };

        // --- API Functions ---
        const getStockQuote = async (ticker) => {
            if (!apiKey) {
                console.error("API Key not set.");
                updateStatus('Error: API Key Missing', 'bg-red-500');
                return null;
            }
            const url = `https://finnhub.io/api/v1/quote?symbol=${ticker.toUpperCase()}&token=${apiKey}`;
            try {
                const response = await fetch(url);
                if (!response.ok) {
                    throw new Error(`API request failed with status ${response.status}`);
                }
                const data = await response.json();
                if (data.c === 0 && data.h === 0) { // Finnhub returns 0 for invalid tickers
                    return null;
                }
                return data; // { c: current price, h: high, l: low, o: open, pc: previous close }
            } catch (error) {
                console.error(`Error fetching data for ${ticker}:`, error);
                updateStatus('API Error', 'bg-red-500');
                return null;
            }
        };

        // --- Application Logic ---
        const saveState = () => {
            localStorage.setItem('paperTraderPortfolio', JSON.stringify(portfolio));
            localStorage.setItem('paperTraderApiKey', apiKey);
        };

        const loadState = () => {
            const savedPortfolio = localStorage.getItem('paperTraderPortfolio');
            const savedApiKey = localStorage.getItem('paperTraderApiKey');
            
            if (savedPortfolio) {
                portfolio = JSON.parse(savedPortfolio);
            }
            
            if (savedApiKey) {
                apiKey = savedApiKey;
                apiKeyInput.value = apiKey;
                apiKeySection.classList.add('hidden');
                mainContent.classList.remove('hidden');
                initializeApp();
            }
        };

        const updateStatus = (text, colorClass) => {
            const dot = statusIndicator.querySelector('div');
            const span = statusIndicator.querySelector('span');
            dot.className = `w-3 h-3 rounded-full ${colorClass}`;
            span.textContent = text;
        };

        const renderHoldings = () => {
            holdingsList.innerHTML = ''; // Clear existing list
            const tickers = Object.keys(portfolio.stocks);

            if (tickers.length === 0) {
                holdingsPlaceholder.classList.remove('hidden');
                holdingsList.appendChild(holdingsPlaceholder);
                return;
            }
            
            tickers.forEach(ticker => {
                const stock = portfolio.stocks[ticker];
                const currentPrice = livePrices[ticker]?.c || stock.purchasePrice; // Use live price if available
                const currentValue = stock.quantity * currentPrice;
                const purchaseValue = stock.quantity * stock.purchasePrice;
                const gainLoss = currentValue - purchaseValue;
                const gainLossPercent = (gainLoss / purchaseValue) * 100;

                const colorClass = gainLoss >= 0 ? 'text-green-400' : 'text-red-400';
                
                const holdingEl = document.createElement('div');
                holdingEl.className = 'bg-gray-800 p-4 rounded-lg grid grid-cols-2 sm:grid-cols-4 gap-4 items-center shadow-md transition-all duration-300 hover:bg-gray-700';
                holdingEl.innerHTML = `
                    <div>
                        <p class="font-bold text-lg text-white ticker-symbol">${ticker}</p>
                        <p class="text-sm text-gray-400">${stock.quantity} Shares</p>
                    </div>
                    <div class="text-right sm:text-left">
                        <p class="font-semibold text-lg text-white">${formatCurrency(currentValue)}</p>
                        <p class="text-sm ${colorClass}">${formatCurrency(gainLoss)} (${gainLossPercent.toFixed(2)}%)</p>
                    </div>
                    <div class="hidden sm:block">
                        <p class="text-sm text-gray-400">Avg. Cost</p>
                        <p class="font-medium text-white">${formatCurrency(stock.purchasePrice)}</p>
                    </div>
                    <div class="hidden sm:block">
                        <p class="text-sm text-gray-400">Current Price</p>
                        <p class="font-medium text-white">${formatCurrency(currentPrice)}</p>
                    </div>
                `;
                holdingsList.appendChild(holdingEl);
            });
        };

        const updatePortfolioSummary = () => {
            let totalStockValue = 0;
            let totalPurchaseValue = 0;
            Object.keys(portfolio.stocks).forEach(ticker => {
                const stock = portfolio.stocks[ticker];
                const currentPrice = livePrices[ticker]?.c || stock.purchasePrice;
                const previousPrice = livePrices[ticker]?.pc || stock.purchasePrice;
                totalStockValue += stock.quantity * currentPrice;
                totalPurchaseValue += stock.quantity * previousPrice;
            });

            const totalPortfolioValue = portfolio.cash + totalStockValue;
            const dailyPl = totalStockValue - totalPurchaseValue;
            
            totalValueEl.textContent = formatCurrency(totalPortfolioValue);
            stocksValueEl.textContent = formatCurrency(totalStockValue);
            cashValueEl.textContent = formatCurrency(portfolio.cash);

            todayPlEl.textContent = formatCurrency(dailyPl);
            if (dailyPl > 0) {
                todayPlEl.className = 'text-2xl font-semibold text-green-400';
            } else if (dailyPl < 0) {
                todayPlEl.className = 'text-2xl font-semibold text-red-400';
            } else {
                todayPlEl.className = 'text-2xl font-semibold text-gray-400';
            }
        };

        const handleBuy = async () => {
            const ticker = tickerInput.value.trim().toUpperCase();
            const quantity = parseInt(quantityInput.value);

            if (!ticker || !quantity || quantity <= 0) {
                showModal('Invalid Input', 'Please enter a valid ticker and a positive quantity.');
                return;
            }

            tradeFeedback.textContent = `Fetching price for ${ticker}...`;
            tradeFeedback.classList.remove('text-red-400', 'text-green-400');

            const quote = await getStockQuote(ticker);

            if (!quote) {
                showModal('Trade Error', `Could not find a valid stock with ticker "${ticker}".`);
                tradeFeedback.textContent = `Invalid ticker: ${ticker}`;
                tradeFeedback.classList.add('text-red-400');
                return;
            }

            const price = quote.c;
            const totalCost = price * quantity;

            if (totalCost > portfolio.cash) {
                showModal('Insufficient Funds', `You need ${formatCurrency(totalCost)} but only have ${formatCurrency(portfolio.cash)}.`);
                tradeFeedback.textContent = 'Not enough cash.';
                tradeFeedback.classList.add('text-red-400');
                return;
            }

            portfolio.cash -= totalCost;
            
            if (portfolio.stocks[ticker]) {
                const existingStock = portfolio.stocks[ticker];
                const newTotalQuantity = existingStock.quantity + quantity;
                const newTotalValue = (existingStock.purchasePrice * existingStock.quantity) + totalCost;
                existingStock.purchasePrice = newTotalValue / newTotalQuantity; // Update average cost
                existingStock.quantity = newTotalQuantity;
            } else {
                portfolio.stocks[ticker] = {
                    quantity: quantity,
                    purchasePrice: price
                };
            }
            
            livePrices[ticker] = quote;
            saveState();
            updateAllUI();
            
            tradeFeedback.textContent = `Successfully bought ${quantity} ${ticker}.`;
            tradeFeedback.classList.add('text-green-400');
            tickerInput.value = '';
            quantityInput.value = '';
        };

        const handleSell = async () => {
            const ticker = tickerInput.value.trim().toUpperCase();
            const quantity = parseInt(quantityInput.value);

            if (!ticker || !quantity || quantity <= 0) {
                showModal('Invalid Input', 'Please enter a valid ticker and a positive quantity.');
                return;
            }

            if (!portfolio.stocks[ticker] || portfolio.stocks[ticker].quantity < quantity) {
                showModal('Invalid Sale', `You don't own enough shares of ${ticker} to sell. You have ${portfolio.stocks[ticker]?.quantity || 0}.`);
                return;
            }

            tradeFeedback.textContent = `Fetching price for ${ticker}...`;
            tradeFeedback.classList.remove('text-red-400', 'text-green-400');

            const quote = await getStockQuote(ticker);
            if (!quote) {
                showModal('Trade Error', `Could not get price for ${ticker}. Please try again.`);
                tradeFeedback.textContent = `API error for ${ticker}.`;
                tradeFeedback.classList.add('text-red-400');
                return;
            }

            const price = quote.c;
            const totalCredit = price * quantity;

            portfolio.cash += totalCredit;
            portfolio.stocks[ticker].quantity -= quantity;

            if (portfolio.stocks[ticker].quantity === 0) {
                delete portfolio.stocks[ticker];
                delete livePrices[ticker];
            }
            
            saveState();
            updateAllUI();

            tradeFeedback.textContent = `Successfully sold ${quantity} ${ticker}.`;
            tradeFeedback.classList.add('text-green-400');
            tickerInput.value = '';
            quantityInput.value = '';
        };
        
        const updateAllUI = () => {
            updatePortfolioSummary();
            renderHoldings();
        };

        const fetchAllLivePrices = async () => {
            updateStatus('Updating prices...', 'bg-yellow-500 animate-pulse');
            const tickers = Object.keys(portfolio.stocks);
            if (tickers.length === 0) {
                updateStatus('Connected', 'bg-green-500');
                return;
            }

            const pricePromises = tickers.map(ticker => getStockQuote(ticker));
            const results = await Promise.all(pricePromises);

            results.forEach((quote, index) => {
                const ticker = tickers[index];
                if (quote) {
                    livePrices[ticker] = quote;
                }
            });
            
            updateAllUI();
            updateStatus('Connected', 'bg-green-500');
        };

        const initializeApp = async () => {
            if (updateInterval) clearInterval(updateInterval);
            await fetchAllLivePrices();
            // Update prices every 60 seconds
            updateInterval = setInterval(fetchAllLivePrices, 60000);
        };

        // --- Event Listeners ---
        saveApiKeyBtn.addEventListener('click', () => {
            const key = apiKeyInput.value.trim();
            if (key) {
                apiKey = key;
                saveState();
                apiKeySection.classList.add('hidden');
                mainContent.classList.remove('hidden');
                initializeApp();
            } else {
                showModal('API Key Required', 'Please enter a valid Finnhub API key to proceed.');
            }
        });

        buyBtn.addEventListener('click', handleBuy);
        sellBtn.addEventListener('click', handleSell);
        modalCloseBtn.addEventListener('click', hideModal);

        // --- Initial Load ---
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            loadState();
            updateAllUI(); // Initial render with stored data
        });

    </script>
</body>
</html>
